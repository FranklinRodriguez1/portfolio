---
import { ui, defaultLang } from "../i18n/ui";
const L = ui[defaultLang];
---

<section class="contact section" id="contact">
  <div class="container contact__grid">
    <div class="contact__intro reveal">
      <h2 class="ml" data-i18n="contact.title">{L["contact.title"]}</h2>
      <p data-i18n="contact.text">{L["contact.text"]}</p>
      <ul class="contact__meta">
        <li>
          <span class="contact__k" data-i18n="contact.emailLabel">{L["contact.emailLabel"]}</span>
          <a href="mailto:franklinrodriguezdev@gmail.com">franklinrodriguezdev@gmail.com</a>
        </li>
        <li>
          <span class="contact__k" data-i18n="contact.phoneLabel">{L["contact.phoneLabel"]}</span>
          <a href="tel:+573103742393">+57 310 374 2393</a>
        </li>
        <li>
          <span class="contact__k" data-i18n="contact.whatsappLabel">{L["contact.whatsappLabel"]}</span>
          <a href="https://wa.me/573016347818" target="_blank" rel="noopener noreferrer">+57 301 634 7818</a>
        </li>
        <li>
          <span class="contact__k" data-i18n="contact.locationLabel">{L["contact.locationLabel"]}</span>
          <span data-i18n="contact.location">{L["contact.location"]}</span>
        </li>
        <li>
          <span class="contact__k">Social</span>
          <span class="contact__social">
            <a href="https://github.com/FranklinRodriguez1" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href="https://www.linkedin.com/in/franklirodriguez/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          </span>
        </li>
      </ul>
    </div>

    <form class="contact__form reveal" name="contact">
      <div class="row">
        <label>
          <span data-i18n="form.identity">{L["form.identity"]}</span>
          <input type="text" name="name" data-i18n-ph="form.name.ph" placeholder={L["form.name.ph"]} required />
        </label>
        <label>
          <span data-i18n="form.email">{L["form.email"]}</span>
          <input type="email" name="email" data-i18n-ph="form.email.ph" placeholder={L["form.email.ph"]} required />
        </label>
      </div>
      <label>
        <span data-i18n="form.brief">{L["form.brief"]}</span>
        <textarea name="brief" rows="5" data-i18n-ph="form.brief.ph" placeholder={L["form.brief.ph"]} required></textarea>
      </label>
      <label class="hp-field" aria-hidden="true">
        Company
        <input type="text" name="company" tabindex="-1" autocomplete="off" />
      </label>
      <button class="btn btn--primary contact__submit" type="submit" data-i18n="form.submit">{L["form.submit"]}</button>
      <p class="contact__status" role="status" aria-live="polite"></p>
    </form>
  </div>
</section>

<style>
  .contact {
    background: var(--bg-elev);
    border-top: 1px solid var(--border);
  }
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }
  .ml {
    white-space: pre-line;
  }
  .contact__intro h2 {
    font-size: clamp(2.4rem, 6vw, 4rem);
  }
  .contact__intro p {
    color: var(--text-muted);
    max-width: 42ch;
    margin: 1.5rem 0 2.5rem;
  }
  .contact__meta {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.4rem;
  }
  .contact__meta li {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .contact__k {
    font-family: var(--font-head);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .contact__meta a:hover {
    color: var(--primary);
  }
  .contact__social {
    display: flex;
    gap: 1.2rem;
  }

  .contact__form {
    display: grid;
    gap: 1.2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }
  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }
  label {
    display: grid;
    gap: 0.5rem;
  }
  label span {
    font-family: var(--font-head);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  input,
  textarea {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: 0.8rem 0.9rem;
    resize: vertical;
    transition: border-color 0.18s ease;
  }
  input::placeholder,
  textarea::placeholder {
    color: var(--text-dim);
  }
  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--primary);
  }
  .contact__submit {
    justify-content: center;
    margin-top: 0.4rem;
  }
  .contact__submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }
  .contact__status {
    margin: 0;
    font-size: 0.85rem;
    text-align: center;
    min-height: 1.2em;
  }
  .contact__status[data-state="error"] {
    color: var(--tertiary);
  }
  .contact__status[data-state="success"] {
    color: var(--primary);
  }
  /* Honeypot: kept in the tab/DOM flow off-screen rather than display:none,
     since naive bots skip fields hidden that way. Invisible to real users. */
  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  @media (max-width: 820px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
    .row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>(".contact__form");
  const btn = form?.querySelector<HTMLButtonElement>(".contact__submit");
  const status = form?.querySelector<HTMLParagraphElement>(".contact__status");

  function t(key: string, fallback: string): string {
    const lang = document.documentElement.getAttribute("lang") || "en";
    const dict = (window as any).__I18N__?.[lang];
    return dict?.[key] ?? fallback;
  }

  form?.addEventListener("submit", async (event) => {
    event.preventDefault();
    if (!btn || !status) return;

    const data = new FormData(form);
    const payload = {
      name: String(data.get("name") ?? ""),
      email: String(data.get("email") ?? ""),
      message: String(data.get("brief") ?? ""),
      company: String(data.get("company") ?? ""),
    };

    btn.disabled = true;
    btn.removeAttribute("data-i18n");
    btn.textContent = t("form.sending", "Sending…");
    status.removeAttribute("data-state");
    status.textContent = "";

    try {
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error("request_failed");

      btn.textContent = t("form.success", "Message Sent ✓");
      status.dataset.state = "success";
      form.reset();
    } catch {
      btn.disabled = false;
      btn.textContent = t("form.submit", "Send Message");
      btn.setAttribute("data-i18n", "form.submit");
      status.dataset.state = "error";
      status.textContent = t("form.error", "Something went wrong — please email me directly.");
    }
  });
</script>
