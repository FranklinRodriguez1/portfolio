---
import { ui, defaultLang } from "../i18n/ui";
const L = ui[defaultLang];
const projects = [
  { name: "TRUX", tag: "work.1.tag", body: "work.1.b", stack: ["Next.js", "TypeScript", "PostgreSQL"], art: "grid" },
  { name: "Semtex", tag: "work.2.tag", body: "work.2.b", stack: ["Node.js", "AI Agents", "MongoDB"], art: "orb" },
  { name: "Atrius Verborum", tag: "work.4.tag", body: "work.4.b", stack: ["JWT", "RBAC", "Swagger"], art: "grid" },
];
---

<section class="work section" id="work">
  <div class="container">
    <header class="work__head reveal">
      <p class="eyebrow" data-i18n="work.eyebrow">{L["work.eyebrow"]}</p>
      <h2 class="ml" data-i18n="work.title">{L["work.title"]}</h2>
      <p class="work__quote" data-i18n="work.quote">{L["work.quote"]}</p>
    </header>

    <div class="work__list">
      {
        projects.map((p, i) => (
          <article class={`case reveal ${i % 2 ? "case--rev" : ""}`}>
            <div class={`case__art art--${p.art}`} aria-hidden="true">
              <div class="art__inner" />
            </div>
            <div class="case__body">
              <p class="case__tag" data-i18n={p.tag}>{L[p.tag]}</p>
              <h3>{p.name}</h3>
              <p class="case__desc" data-i18n={p.body}>{L[p.body]}</p>
              <ul class="case__stack">
                {p.stack.map((s) => <li>{s}</li>)}
              </ul>
              <a class="case__link" href="#contact" data-i18n="work.link">{L["work.link"]}</a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .work__head {
    margin-bottom: 4rem;
  }
  .ml {
    white-space: pre-line;
  }
  .work__head h2 {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    margin: 0.8rem 0 1.5rem;
  }
  .work__quote {
    max-width: 44ch;
    color: var(--text-dim);
    font-style: italic;
    margin: 0;
  }
  .work__list {
    display: grid;
    gap: clamp(2.5rem, 5vw, 4.5rem);
  }
  .case {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: center;
  }
  .case--rev .case__art {
    order: 2;
  }
  .case__art {
    aspect-ratio: 16 / 11;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
    position: relative;
  }
  .art__inner {
    position: absolute;
    inset: 0;
  }
  .art--grid .art__inner {
    background-image: linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 26px 26px;
    background-position: center;
  }
  .art--grid::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 45%, rgba(0, 123, 255, 0.25), transparent 60%);
  }
  .art--orb .art__inner {
    background: radial-gradient(circle at 50% 50%, #2a2a30, #0c0c0e 70%);
  }
  .art--orb::after {
    content: "";
    position: absolute;
    width: 46%;
    aspect-ratio: 1;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: conic-gradient(from 210deg, #3a3a44, #14141a, #4a4a55, #14141a);
    box-shadow: 0 0 60px rgba(0, 123, 255, 0.25);
  }
  .art--mesh .art__inner {
    background:
      radial-gradient(circle at 30% 40%, rgba(216, 87, 1, 0.35), transparent 45%),
      radial-gradient(circle at 70% 60%, rgba(0, 123, 255, 0.3), transparent 45%),
      #0c0c0e;
  }

  .case__tag {
    font-family: var(--font-head);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--tertiary);
    margin: 0 0 0.7rem;
  }
  .case__body h3 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 0.9rem;
  }
  .case__desc {
    color: var(--text-muted);
    margin: 0 0 1.3rem;
    max-width: 52ch;
  }
  .case__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }
  .case__stack li {
    font-family: var(--font-head);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.32rem 0.7rem;
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    color: var(--text-muted);
  }
  .case__link {
    font-family: var(--font-head);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--primary);
  }
  .case__link:hover {
    text-decoration: underline;
  }

  @media (max-width: 820px) {
    .case,
    .case--rev .case__art {
      grid-template-columns: 1fr;
      order: 0;
    }
  }
</style>
