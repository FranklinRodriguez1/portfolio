---
import { ui, defaultLang } from "../i18n/ui";
const L = ui[defaultLang];
---

<section class="contact section" id="contact">
  <div class="container contact__grid">
    <div class="contact__intro reveal">
      <h2 class="ml" data-i18n="contact.title">{L["contact.title"]}</h2>
      <p data-i18n="contact.text">{L["contact.text"]}</p>
      <ul class="contact__meta">
        <li>
          <span class="contact__k" data-i18n="contact.emailLabel">{L["contact.emailLabel"]}</span>
          <a href="mailto:franklinrodriguezdev@gmail.com">franklinrodriguezdev@gmail.com</a>
        </li>
        <li>
          <span class="contact__k" data-i18n="contact.locationLabel">{L["contact.locationLabel"]}</span>
          <span data-i18n="contact.location">{L["contact.location"]}</span>
        </li>
        <li>
          <span class="contact__k">Social</span>
          <span class="contact__social">
            <a href="https://github.com/FranklinRodriguez1" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href="https://www.linkedin.com/in/franklirodriguez/" target="_blank" rel="noopener noreferrer">LinkedIn</a>
          </span>
        </li>
      </ul>
    </div>

    <form class="contact__form reveal" name="contact" onsubmit="return false">
      <div class="row">
        <label>
          <span data-i18n="form.identity">{L["form.identity"]}</span>
          <input type="text" name="name" data-i18n-ph="form.name.ph" placeholder={L["form.name.ph"]} required />
        </label>
        <label>
          <span data-i18n="form.email">{L["form.email"]}</span>
          <input type="email" name="email" data-i18n-ph="form.email.ph" placeholder={L["form.email.ph"]} required />
        </label>
      </div>
      <label>
        <span data-i18n="form.brief">{L["form.brief"]}</span>
        <textarea name="brief" rows="5" data-i18n-ph="form.brief.ph" placeholder={L["form.brief.ph"]}></textarea>
      </label>
      <button class="btn btn--primary contact__submit" type="submit" data-i18n="form.submit">{L["form.submit"]}</button>
    </form>
  </div>
</section>

<style>
  .contact {
    background: var(--bg-elev);
    border-top: 1px solid var(--border);
  }
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
  }
  .ml {
    white-space: pre-line;
  }
  .contact__intro h2 {
    font-size: clamp(2.4rem, 6vw, 4rem);
  }
  .contact__intro p {
    color: var(--text-muted);
    max-width: 42ch;
    margin: 1.5rem 0 2.5rem;
  }
  .contact__meta {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.4rem;
  }
  .contact__meta li {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .contact__k {
    font-family: var(--font-head);
    font-size: 0.68rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  .contact__meta a:hover {
    color: var(--primary);
  }
  .contact__social {
    display: flex;
    gap: 1.2rem;
  }

  .contact__form {
    display: grid;
    gap: 1.2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }
  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }
  label {
    display: grid;
    gap: 0.5rem;
  }
  label span {
    font-family: var(--font-head);
    font-size: 0.68rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
  }
  input,
  textarea {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: 0.8rem 0.9rem;
    resize: vertical;
    transition: border-color 0.18s ease;
  }
  input::placeholder,
  textarea::placeholder {
    color: var(--text-dim);
  }
  input:focus,
  textarea:focus {
    outline: none;
    border-color: var(--primary);
  }
  .contact__submit {
    justify-content: center;
    margin-top: 0.4rem;
  }
  @media (max-width: 820px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }
    .row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>(".contact__form");
  form?.addEventListener("submit", () => {
    const btn = form.querySelector<HTMLButtonElement>(".contact__submit");
    const lang = document.documentElement.getAttribute("lang") || "en";
    const dict = (window as any).__I18N__?.[lang];
    if (btn) {
      btn.textContent = dict?.["form.success"] ?? "Sent ✓";
      btn.removeAttribute("data-i18n");
      btn.disabled = true;
      btn.style.opacity = "0.7";
    }
    form.reset();
  });
</script>
