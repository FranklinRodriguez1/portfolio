---
import { ui, defaultLang } from "../i18n/ui";
const L = ui[defaultLang];
const links = [
  { key: "nav.work", href: "#work" },
  { key: "nav.philosophy", href: "#philosophy" },
  { key: "nav.stack", href: "#stack" },
];
---

<header class="site-header" id="top">
  <div class="container header__inner">
    <a class="brand" href="#top">
      <span class="brand__mark"></span>
      Franklin<span class="brand__dot"></span>
    </a>

    <nav class="nav" aria-label="Primary">
      {links.map((l) => <a href={l.href} data-i18n={l.key}>{L[l.key]}</a>)}
    </nav>

    <div class="header__tools">
      <div class="lang-switch" role="group" data-i18n-aria="toggle.lang" aria-label={L["toggle.lang"]}>
        <button class="lang-btn" data-lang="en" type="button">EN</button>
        <button class="lang-btn" data-lang="es" type="button">ES</button>
      </div>
      <button class="theme-btn" type="button" data-i18n-aria="toggle.theme" aria-label={L["toggle.theme"]}>
        <svg class="i-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg class="i-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
      </button>
      <a class="btn btn--primary header__cta" href="#contact" data-i18n="cta.start">{L["cta.start"]}</a>
    </div>

    <button class="nav-toggle" aria-label="Menu">
      <span></span><span></span>
    </button>
  </div>

  <nav class="nav-mobile" aria-label="Mobile">
    {links.map((l) => <a href={l.href} data-i18n={l.key}>{L[l.key]}</a>)}
    <a class="btn btn--primary" href="#contact" data-i18n="cta.start">{L["cta.start"]}</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 72%, transparent);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
  }
  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 72px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 1.05rem;
    white-space: nowrap;
  }
  .brand__mark {
    width: 18px;
    height: 18px;
    border-radius: 5px;
    background: var(--primary);
    box-shadow: 0 0 0 3px var(--primary-soft);
  }
  .brand__dot {
    color: var(--primary);
  }
  .nav {
    display: flex;
    gap: 2rem;
    margin-left: auto;
    font-family: var(--font-head);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  .nav a {
    color: var(--text-muted);
    transition: color 0.18s ease;
  }
  .nav a:hover {
    color: var(--text);
  }

  .header__tools {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .lang-switch {
    display: inline-flex;
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    overflow: hidden;
  }
  .lang-btn {
    font-family: var(--font-head);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 0.4rem 0.6rem;
    background: transparent;
    color: var(--text-muted);
    border: none;
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease;
  }
  .lang-btn[aria-pressed="true"] {
    background: var(--primary);
    color: #fff;
  }
  .theme-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 34px;
    border: 1px solid var(--border-strong);
    border-radius: 8px;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.18s ease, border-color 0.18s ease;
  }
  .theme-btn:hover {
    color: var(--primary);
    border-color: var(--primary);
  }
  .theme-btn .i-moon {
    display: none;
  }
  :root[data-theme="light"] .theme-btn .i-sun {
    display: none;
  }
  :root[data-theme="light"] .theme-btn .i-moon {
    display: block;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }
  .nav-toggle span {
    width: 24px;
    height: 2px;
    background: var(--text);
    transition: transform 0.2s ease;
  }

  .nav-mobile {
    display: none;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0 var(--gutter) 1.25rem;
  }
  .nav-mobile a:not(.btn) {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
    font-family: var(--font-head);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-size: 0.82rem;
    color: var(--text-muted);
  }
  .nav-mobile .btn {
    margin-top: 0.6rem;
    justify-content: center;
  }

  @media (max-width: 960px) {
    .nav,
    .header__cta {
      display: none;
    }
    .nav-toggle {
      display: flex;
    }
    .site-header.open .nav-mobile {
      display: flex;
    }
    .site-header.open .nav-toggle span:first-child {
      transform: translateY(3.5px) rotate(45deg);
    }
    .site-header.open .nav-toggle span:last-child {
      transform: translateY(-3.5px) rotate(-45deg);
    }
  }
</style>

<script>
  const header = document.querySelector(".site-header");
  const toggle = header?.querySelector(".nav-toggle");
  toggle?.addEventListener("click", () => header?.classList.toggle("open"));
  header?.querySelectorAll(".nav-mobile a").forEach((a) =>
    a.addEventListener("click", () => header.classList.remove("open")),
  );
</script>
