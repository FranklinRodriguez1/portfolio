---
import { Image } from "astro:assets";
import { ui, defaultLang } from "../i18n/ui";
import truxImg1 from "../trux/img1.jpeg";
import truxImg2 from "../trux/img2.jpeg";
import truxImg3 from "../trux/img3.jpeg";
import truxImg4 from "../trux/img4.jpeg";

const L = ui[defaultLang];
const truxImages = [truxImg1, truxImg2, truxImg3, truxImg4];
const projects = [
  {
    name: "TRUX",
    tag: "work.1.tag",
    body: "work.1.b",
    stack: ["Next.js", "TypeScript", "PostgreSQL"],
    art: "grid",
    images: truxImages,
  },
  { name: "Atrius Verborum", tag: "work.4.tag", body: "work.4.b", stack: ["JWT", "RBAC", "Swagger"], art: "grid" },
];
---

<section class="work section" id="work">
  <div class="container">
    <header class="work__head reveal">
      <p class="eyebrow" data-i18n="work.eyebrow">{L["work.eyebrow"]}</p>
      <h2 class="ml" data-i18n="work.title">{L["work.title"]}</h2>
      <p class="work__quote" data-i18n="work.quote">{L["work.quote"]}</p>
    </header>

    <div class="work__list">
      {
        projects.map((p, i) => (
          <article class={`case reveal ${i % 2 ? "case--rev" : ""}`}>
            {p.images ? (
              <div
                class="case__carousel"
                data-carousel
                data-open-modal={i}
                role="button"
                tabindex="0"
                aria-label={`${p.name} screenshots — open project details`}
              >
                {p.images.map((img, n) => (
                  <Image
                    src={img}
                    alt={`${p.name} — screenshot ${n + 1}`}
                    class="carousel__img"
                    data-active={n === 0 ? "true" : "false"}
                    widths={[400, 700, 960]}
                    sizes="(max-width: 820px) 100vw, 50vw"
                    loading={i === 0 && n === 0 ? "eager" : "lazy"}
                  />
                ))}
                <div class="carousel__dots" role="tablist" aria-label="Screenshots">
                  {p.images.map((_, n) => (
                    <button
                      type="button"
                      class="carousel__dot"
                      data-index={n}
                      aria-label={`Screenshot ${n + 1}`}
                      aria-selected={n === 0 ? "true" : "false"}
                    />
                  ))}
                </div>
              </div>
            ) : (
              <div
                class={`case__art art--${p.art}`}
                data-open-modal={i}
                role="button"
                tabindex="0"
                aria-label={`${p.name} — open project details`}
              >
                <div class="art__inner" aria-hidden="true" />
                <span class="case__badge" data-i18n="work.comingSoon">{L["work.comingSoon"]}</span>
              </div>
            )}
            <div class="case__body">
              <p class="case__tag" data-i18n={p.tag}>{L[p.tag]}</p>
              <h3>{p.name}</h3>
              <p class="case__desc" data-i18n={p.body}>{L[p.body]}</p>
              <ul class="case__stack">
                {p.stack.map((s) => <li>{s}</li>)}
              </ul>
              <button type="button" class="case__link" data-open-modal={i} data-i18n="work.link">
                {L["work.link"]}
              </button>
            </div>
          </article>
        ))
      }
    </div>

    {
      projects.map((p, i) => (
        <div class="project-modal" id={`project-modal-${i}`} data-modal aria-hidden="true">
          <div class="project-modal__overlay" data-close-modal />
          <div
            class="project-modal__panel"
            role="dialog"
            aria-modal="true"
            aria-labelledby={`project-modal-title-${i}`}
          >
            <button
              type="button"
              class="project-modal__close"
              data-close-modal
              data-i18n-aria="work.modal.close"
              aria-label={L["work.modal.close"]}
            >
              ×
            </button>

            {p.images ? (
              <div class="project-modal__gallery">
                {p.images.map((img, n) => (
                  <Image
                    src={img}
                    alt={`${p.name} — screenshot ${n + 1}`}
                    class="project-modal__img"
                    widths={[400, 700, 960]}
                    sizes="(max-width: 700px) 100vw, 420px"
                    loading="lazy"
                  />
                ))}
              </div>
            ) : (
              <div class={`project-modal__art art--${p.art}`}>
                <div class="art__inner" aria-hidden="true" />
                <span class="case__badge" data-i18n="work.comingSoon">{L["work.comingSoon"]}</span>
              </div>
            )}

            <div class="project-modal__body">
              <p class="case__tag" data-i18n={p.tag}>{L[p.tag]}</p>
              <h3 id={`project-modal-title-${i}`}>{p.name}</h3>
              <p class="case__desc" data-i18n={p.body}>{L[p.body]}</p>
              <p class="project-modal__label" data-i18n="work.modal.stack">{L["work.modal.stack"]}</p>
              <ul class="case__stack">
                {p.stack.map((s) => <li>{s}</li>)}
              </ul>
              <a class="case__link" href="#contact" data-close-modal data-i18n="cta.start">
                {L["cta.start"]}
              </a>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>

<style>
  .work__head {
    margin-bottom: 4rem;
  }
  .ml {
    white-space: pre-line;
  }
  .work__head h2 {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    margin: 0.8rem 0 1.5rem;
  }
  .work__quote {
    max-width: 44ch;
    color: var(--text-dim);
    font-style: italic;
    margin: 0;
  }
  .work__list {
    display: grid;
    gap: clamp(2.5rem, 5vw, 4.5rem);
  }
  .case {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: center;
  }
  .case--rev .case__art,
  .case--rev .case__carousel {
    order: 2;
  }
  .case__carousel {
    aspect-ratio: 16 / 11;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
    position: relative;
  }
  .carousel__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    opacity: 0;
    transition: opacity 0.6s ease;
  }
  .carousel__img[data-active="true"] {
    opacity: 1;
  }
  .carousel__dots {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.9rem;
    display: flex;
    justify-content: center;
    gap: 0.45rem;
  }
  .carousel__dot {
    width: 8px;
    height: 8px;
    padding: 0;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.5);
    background: rgba(10, 10, 10, 0.35);
    cursor: pointer;
    transition: background 0.18s ease, transform 0.18s ease;
  }
  .carousel__dot[aria-selected="true"] {
    background: var(--primary);
    border-color: var(--primary);
    transform: scale(1.15);
  }
  @media (prefers-reduced-motion: reduce) {
    .carousel__img {
      transition: none;
    }
  }
  .case__art {
    aspect-ratio: 16 / 11;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .art__inner {
    position: absolute;
    inset: 0;
  }
  .case__badge {
    position: relative;
    z-index: 1;
    font-family: var(--font-head);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    padding: 0.55rem 1.1rem;
    border-radius: 999px;
    border: 1px solid var(--border-strong);
    background: color-mix(in srgb, var(--bg) 70%, transparent);
    backdrop-filter: blur(6px);
  }
  .art--grid .art__inner {
    background-image: linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 26px 26px;
    background-position: center;
  }
  .art--grid::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 50% 45%, rgba(0, 123, 255, 0.25), transparent 60%);
  }
  .art--orb .art__inner {
    background: radial-gradient(circle at 50% 50%, #2a2a30, #0c0c0e 70%);
  }
  .art--orb::after {
    content: "";
    position: absolute;
    width: 46%;
    aspect-ratio: 1;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: conic-gradient(from 210deg, #3a3a44, #14141a, #4a4a55, #14141a);
    box-shadow: 0 0 60px rgba(0, 123, 255, 0.25);
  }
  .art--mesh .art__inner {
    background:
      radial-gradient(circle at 30% 40%, rgba(216, 87, 1, 0.35), transparent 45%),
      radial-gradient(circle at 70% 60%, rgba(0, 123, 255, 0.3), transparent 45%),
      #0c0c0e;
  }

  .case__tag {
    font-family: var(--font-head);
    font-size: 0.72rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--tertiary);
    margin: 0 0 0.7rem;
  }
  .case__body h3 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 0.9rem;
  }
  .case__desc {
    color: var(--text-muted);
    margin: 0 0 1.3rem;
    max-width: 52ch;
  }
  .case__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
  }
  .case__stack li {
    font-family: var(--font-head);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.32rem 0.7rem;
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    color: var(--text-muted);
  }
  .case__link {
    font-family: var(--font-head);
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--primary);
  }
  .case__link:hover {
    text-decoration: underline;
  }

  @media (max-width: 820px) {
    .case,
    .case--rev .case__art,
    .case--rev .case__carousel {
      grid-template-columns: 1fr;
      order: 0;
    }
  }

  .case__carousel,
  .case__art {
    cursor: pointer;
  }
  .case__link {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
  }

  .project-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 1.5rem;
  }
  .project-modal[data-open="true"] {
    display: flex;
  }
  .project-modal__overlay {
    position: absolute;
    inset: 0;
    background: rgba(6, 6, 8, 0.72);
    backdrop-filter: blur(4px);
  }
  .project-modal__panel {
    position: relative;
    z-index: 1;
    width: min(760px, 100%);
    max-height: min(88vh, 900px);
    overflow-y: auto;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: clamp(1.5rem, 3vw, 2.5rem);
  }
  .project-modal__close {
    position: sticky;
    top: 0;
    float: right;
    margin-left: 1rem;
    width: 2.2rem;
    height: 2.2rem;
    line-height: 1;
    font-size: 1.4rem;
    border-radius: 50%;
    border: 1px solid var(--border-strong);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
  }
  .project-modal__gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }
  .project-modal__img {
    width: 100%;
    height: 100%;
    aspect-ratio: 16 / 11;
    object-fit: cover;
    object-position: top;
    border-radius: calc(var(--radius) * 0.6);
    border: 1px solid var(--border);
  }
  .project-modal__art {
    aspect-ratio: 16 / 9;
    border-radius: calc(var(--radius) * 0.6);
    border: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
  .project-modal__label {
    font-family: var(--font-head);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 0 0 0.6rem;
  }
  .project-modal__body .case__link {
    display: inline-block;
    background: var(--primary);
    color: var(--bg);
    padding: 0.6rem 1.2rem;
    border-radius: 999px;
    margin-top: 0.5rem;
  }
  .project-modal__body .case__link:hover {
    text-decoration: none;
    opacity: 0.9;
  }

  @media (max-width: 540px) {
    .project-modal__gallery {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

  document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((carousel) => {
    const imgs = Array.from(carousel.querySelectorAll<HTMLElement>(".carousel__img"));
    const dots = Array.from(carousel.querySelectorAll<HTMLButtonElement>(".carousel__dot"));
    if (imgs.length <= 1) return;

    let index = 0;
    let timer: ReturnType<typeof setInterval> | undefined;

    function show(next: number) {
      index = (next + imgs.length) % imgs.length;
      imgs.forEach((img, n) => img.setAttribute("data-active", String(n === index)));
      dots.forEach((dot, n) => dot.setAttribute("aria-selected", String(n === index)));
    }

    function start() {
      stop();
      if (reduceMotion.matches) return;
      timer = setInterval(() => show(index + 1), 10000);
    }

    function stop() {
      if (timer) clearInterval(timer);
    }

    dots.forEach((dot, n) => {
      dot.addEventListener("click", (e) => {
        e.stopPropagation();
        show(n);
        start();
      });
    });

    carousel.addEventListener("mouseenter", stop);
    carousel.addEventListener("mouseleave", start);
    carousel.addEventListener("focusin", stop);
    carousel.addEventListener("focusout", start);

    show(0);
    start();
  });

  // Project detail modals
  let lastFocused: HTMLElement | null = null;

  function openModal(index: string) {
    const modal = document.getElementById(`project-modal-${index}`);
    if (!modal) return;
    lastFocused = document.activeElement as HTMLElement;
    modal.setAttribute("data-open", "true");
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    modal.querySelector<HTMLButtonElement>(".project-modal__close")?.focus();
  }

  function closeModal(modal: HTMLElement) {
    modal.removeAttribute("data-open");
    modal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    lastFocused?.focus();
  }

  document.querySelectorAll<HTMLElement>("[data-open-modal]").forEach((trigger) => {
    trigger.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest(".carousel__dot")) return;
      openModal(trigger.dataset.openModal!);
    });
    trigger.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        openModal(trigger.dataset.openModal!);
      }
    });
  });

  document.querySelectorAll<HTMLElement>(".project-modal").forEach((modal) => {
    modal.querySelectorAll<HTMLElement>("[data-close-modal]").forEach((el) => {
      el.addEventListener("click", () => closeModal(modal));
    });
  });

  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    document.querySelectorAll<HTMLElement>('.project-modal[data-open="true"]').forEach((modal) => closeModal(modal));
  });
</script>
